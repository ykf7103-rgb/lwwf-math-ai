{
  "name": "第12課：有趣的乘法",
  "children": [
    {
      "name": "學習目標1：乘以10/100/1000",
      "children": [
        {
          "name": "核心規律",
          "children": [
            { "name": "×10：小數點向右移1位" },
            { "name": "×100：小數點向右移2位" },
            { "name": "×1000：小數點向右移3位" }
          ]
        },
        {
          "name": "例題",
          "children": [
            { "name": "0.123×10 = 1.23" },
            { "name": "0.123×100 = 12.3" },
            { "name": "0.123×1000 = 123" },
            { "name": "4×100 = 400（整數先補小數點）" }
          ]
        },
        {
          "name": "口訣",
          "children": [
            { "name": "乘的數有幾個0，小數點就向右移幾位" }
          ]
        },
        {
          "name": "常見錯誤",
          "children": [
            { "name": "❌ 0.05×1000=500 → ✅ 50" },
            { "name": "❌ 0.15×100=1.5 → ✅ 15" }
          ]
        }
      ]
    },
    {
      "name": "學習目標2：乘以0.1/0.01/0.001",
      "children": [
        {
          "name": "核心規律",
          "children": [
            { "name": "×0.1：小數點向左移1位（等於÷10）" },
            { "name": "×0.01：小數點向左移2位（等於÷100）" },
            { "name": "×0.001：小數點向左移3位（等於÷1000）" }
          ]
        },
        {
          "name": "例題",
          "children": [
            { "name": "123.4×0.1 = 12.34" },
            { "name": "123.4×0.01 = 1.234" },
            { "name": "123.4×0.001 = 0.1234" },
            { "name": "2.6×0.001 = 0.0026（補0）" }
          ]
        },
        {
          "name": "口訣",
          "children": [
            { "name": "乘大右移變更大，乘小左移變更小" }
          ]
        },
        {
          "name": "常見錯誤",
          "children": [
            { "name": "❌ 2.6×0.001=0.26 → ✅ 0.0026" },
            { "name": "❌ 0.1×0.35=3.5 → ✅ 0.035" }
          ]
        }
      ]
    },
    {
      "name": "學習目標3：單位轉換",
      "children": [
        {
          "name": "長度單位",
          "children": [
            { "name": "公里→米：×1000" },
            { "name": "米→厘米：×100" },
            { "name": "厘米→毫米：×10" }
          ]
        },
        {
          "name": "重量單位",
          "children": [
            { "name": "公斤→克：×1000" }
          ]
        },
        {
          "name": "容量單位",
          "children": [
            { "name": "升→毫升：×1000" }
          ]
        },
        {
          "name": "例題",
          "children": [
            { "name": "1.05米 = 105厘米" },
            { "name": "0.72公里 = 720米" },
            { "name": "6.2公斤 = 6200克" },
            { "name": "8.64升 = 8640毫升" }
          ]
        },
        {
          "name": "口訣",
          "children": [
            { "name": "大單位轉小單位，要用乘法" }
          ]
        }
      ]
    }
  ]
}
